{
  "//": "Copy to .mcp.json (gitignored) to register the CREST MCP server with Claude Code.",
  "//how": "The backend runs in Docker (build_debug.sh up), so the MCP server runs INSIDE the backend container: it already has unixodbc, env/.env.dev, and network access to mssql/redis/minio. Nothing to install or configure on the host.",
  "//deps": "The debug image installs the mcp SDK (services/server/Dockerfile). If your image predates that, run once: docker compose -f docker-compose.debug.yml exec backend pip install 'mcp>=1.9,<2'",
  "//identity": "Add '-e','MCP_IDENTITY=<email>' to the args to attribute launched jobs to a user. It MUST be an existing users.email (triggered_by is an FK) or launches fail — e.g. 'admin'. Jobs launched via MCP are tagged AUTO in job history; the New Model wizard is MANUAL.",
  "//host-alt": "To run on the host instead (no Docker for the app): install unixodbc + msodbcsql18, pip install -r services/server/requirements-mcp.txt, and set command=python3 with env {PYTHONPATH:services/server, CONFIG_NAME:development, ENV_FILE:env/.env.dev, JWT_SECRET_KEY:..., APP_DB_SERVER:tcp:localhost,1433, REDIS_HOST:localhost, MINIO_ENDPOINT:localhost:9100}. Note MinIO is published on 9100, and redis is not published by docker-compose.debug.yml.",
  "mcpServers": {
    "crest": {
      "command": "docker",
      "args": [
        "compose",
        "-f",
        "docker-compose.debug.yml",
        "exec",
        "-T",
        "-e",
        "MCP_IDENTITY=admin",
        "backend",
        "python3",
        "-m",
        "project.mcp_server"
      ]
    }
  }
}
