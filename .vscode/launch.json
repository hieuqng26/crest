{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "env": {"PYTHONPATH": "${workspaceRoot}\\services\\server"},
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            // "module": "test.${fileBasenameNoExtension}",
            "console": "integratedTerminal",
            "cwd":"${workspaceRoot}\\services\\server"
        },
        {
            "type": "msedge",
            "request": "launch",
            "name": "Debug Vue in Edge",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}\\services\\client"
        },
        {
            "name": "Python: Backend",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "0.0.0.0",
                "port": 5678
            },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}\\services\\server",
                    "remoteRoot": "."
                }
            ]
        },
        {
            "name": "Python: Worker",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "0.0.0.0",
                "port": 5679
            },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}\\services\\server",
                    "remoteRoot": "."
                }
            ]
        },
        {
            "env": {"PYTHONPATH": "${workspaceRoot}\\server"},
            "name": "Python Profiler: Current File",
            "type": "debugpy",
            "request": "launch",
            "module": "cProfile",
            "args": [
                "-o", "/temp/tmp.prof", "${file}"
            ],
            "cwd":"${workspaceRoot}\\server",
            "postDebugTask": "Display SnakeViz profiler result",
        },
    ]
}