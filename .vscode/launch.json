{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "env": {"PYTHONPATH": "${workspaceRoot}/services/server"},
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            // "module": "test.${fileBasenameNoExtension}",
            "console": "integratedTerminal",
            "cwd":"${workspaceRoot}/services/server"
        },
        {
            "type": "msedge",
            "request": "launch",
            "name": "Debug Vue in Edge",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/services/client"
        },
        {
            "name": "Python: Backend",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5678
            },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}/services/server",
                    "remoteRoot": "/usr/src/app"
                }
            ]
        },
        {
            "name": "Python: Worker",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5679
            },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}/services/server",
                    "remoteRoot": "/usr/src/app"
                }
            ]
        }
    ]
}