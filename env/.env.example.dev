# ROLE

# LOG FIELD — optional trusted header for the client IP (ProxyFix already
# resolves it via request.remote_addr). Canonical name IP_ADDRESS_HEADER_FIELD.
# IP_ADDRESS_HEADER_FIELD="X-Forwarded-For"

# FOR TEST

# REQUEST GUARDING
# /query must use a READ-ONLY Risk DB login (db_datareader); it's the real
# write-prevention boundary, not the app's SELECT/WITH check.
# RISK_DB_CONN_STR=
RISK_DB_QUERY_MAX_ROWS=100000
RISK_DB_QUERY_TIMEOUT_S=30
MAX_CONTENT_LENGTH_MB=1024
RATELIMIT_AUTH=10 per minute

# seed admin user
SEED_ADMIN_EMAIL=admin
SEED_ADMIN_PASSWORD=admin@123!

# ── MCP SERVER (remote streamable-http transport) ─────────────────────────────
# Only needed for the `mcp` service (SERVICE_NAME=mcp). stdio needs none of this.
# MCP_TRANSPORT=streamable-http            # 'stdio' (default) | 'streamable-http'
# MCP_HOST=0.0.0.0
# MCP_PORT=8090
# MCP_AUTH_TOKEN=                          # REQUIRED for streamable-http (fails closed). Strong secret shared with clients.
# MCP_IDENTITY=admin                       # triggered_by on launched runs; must be an existing users.email
# MCP_ALLOWED_HOSTS=mcp.example.com        # comma-separated; your public hostname(s) for DNS-rebinding protection
# MCP_ALLOWED_ORIGINS=                     # comma-separated; defaults to MCP_ALLOWED_HOSTS
# MCP_DISABLE_DNS_REBINDING_PROTECTION=false  # true only when a trusted ingress already validates Host
